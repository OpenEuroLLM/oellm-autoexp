Bootstrap: docker
From: ${BASE_IMAGE}

%labels
    Author OpenSci
    Version 0.1.0
    Base ${BASE_IMAGE}
    Description Megatron container based on NVIDIA PyTorch with full HPC support

%environment
    export PYTHONNOUSERSITE=1
    export CUDA_HOME=/usr/local/cuda
    export PATH=$CUDA_HOME/bin:$PATH
    export PYTHONPATH=/workspace/oellm-autoexp/submodules/Megatron-LM:/workspace/oellm-autoexp:${PYTHONPATH}
    export OELLM_AUTOEXP_CACHE=/workspace/cache
    export HF_HOME=/workspace/cache/hf

%files
    ${REPO_ROOT} /workspace/oellm-autoexp
    ${REQUIREMENTS_PATH} /workspace/${REQUIREMENTS_BASENAME}
    /e/software/default/stages/2026/software/NVSHMEM/3.5.21-gompi-2025b-CUDA-13/ /opt/nvshmem/
%post
ln -sf /usr/local/cuda/compat/lib.real /usr/local/cuda/compat/lib

mkdir -p /workspace/cache
cd /workspace

pip install --upgrade pip setuptools wheel

python3 /workspace/oellm-autoexp/container/gen_constraints.py \
    --output /workspace/constraints.installed.txt \
    --exclude pip setuptools wheel huggingface_hub

if [ -f "/workspace/${REQUIREMENTS_BASENAME}" ]; then
    python3 -m pip install --no-cache-dir \
        -c /workspace/constraints.installed.txt \
        -r "/workspace/${REQUIREMENTS_BASENAME}"
fi

if [ -d "/workspace/oellm-autoexp/submodules/Megatron-LM" ]; then
    python3 -m pip install --no-cache-dir \
        -c /workspace/constraints.installed.txt \
        -e /workspace/oellm-autoexp/submodules/Megatron-LM
fi

python3 -m pip install --no-cache-dir \
    -c /workspace/constraints.installed.txt \
    -e /workspace/oellm-autoexp

python3 -m pip uninstall -y megatron-core || true

# load NVSHMEM on JUPITER before
# module load Stages/2026
# module load GCC/14.3.0
# module load OpenMPI/5.0.8
# module load NVSHMEM/3.5.21-CUDA-13
export NVSHMEM_DIR=/opt/nvshmem
export CPATH=/usr/local/cuda-13.0/targets/sbsa-linux/include/cccl:$CPATH
export CXXFLAGS="-I/usr/local/cuda-13.0/targets/sbsa-linux/include/cccl $CXXFLAGS"
export CPLUS_INCLUDE_PATH=/usr/local/cuda-13.0/targets/sbsa-linux/include/cccl:$CPLUS_INCLUDE_PATH

# install deepep
git clone https://github.com/deepseek-ai/deepep.git
export TORCH_CUDA_ARCH_LIST="9.0" # later versions not needed on JUPITER: 10.0 11.0 12.0+PTX
pip install --no-build-isolation ./deepep


cd oellm-autoexp
pip install -e .[dev]

# startup script that fixes CUDA symlinks
mkdir -p /.singularity.d/env
cat > /.singularity.d/env/99-cuda-fix.sh << 'EOFENV'
#!/bin/bash
# Fix CUDA symlinks for Triton when --nv is used
if [ -f /.singularity.d/libs/libcuda.so.1 ]; then
mkdir -p /usr/local/cuda/lib64 /usr/local/cuda/compat/lib 2>/dev/null
ln -sf /.singularity.d/libs/libcuda.so.1 /usr/local/cuda/lib64/libcuda.so.1 2>/dev/null
ln -sf /usr/local/cuda/lib64/libcuda.so.1 /usr/local/cuda/lib64/libcuda.so 2>/dev/null
ln -sf /.singularity.d/libs/libcuda.so.1 /usr/local/cuda/compat/lib/libcuda.so.1 2>/dev/null
ln -sf /usr/local/cuda/compat/lib/libcuda.so.1 /usr/local/cuda/compat/lib/libcuda.so 2>/dev/null
fi
export LD_LIBRARY_PATH=/.singularity.d/libs:/usr/local/cuda/lib64:${LD_LIBRARY_PATH}
EOFENV
chmod +x /.singularity.d/env/99-cuda-fix.sh


%runscript
cd /workspace/oellm-autoexp
exec "$@"

%startscript
cd /workspace/oellm-autoexp
exec "$@"

%test
cd /workspace/oellm-autoexp
python scripts/run_autoexp.py --help >/dev/null

%help
    Build with container/build_container.sh and run via
    `apptainer exec MegatronTraining.sif python -m oellm_autoexp.plan`.
